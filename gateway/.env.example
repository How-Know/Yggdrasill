# Gateway / workers — copy to .env and fill (do not commit .env)

# MQTT gateway (src/index.js)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# MQTT_URL=

# AlimTalk workers (attendance + makeup): service role required
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# BIZPPURIO_ACCOUNT=
# BIZPPURIO_PASSWORD=
# BIZPPURIO_DOMAIN=api.bizppurio.com

# 출결 워커 (attendance_alimtalk_worker.js)
# ALIMTALK_BATCH_SIZE=20
# ALIMTALK_MAX_ATTEMPTS=5
# WORKER_INTERVAL_MS=60000
# ALIMTALK_ONLY_TODAY=1

# 보강 워커 (makeup_alimtalk_worker.js) — 1일 때만 큐 처리
# MAKEUP_ALIMTALK_ENABLED=1
# MAKEUP_ALIMTALK_ONLY_TODAY_QUEUE=1
# MAKEUP_ALIMTALK_BATCH_SIZE=20
# MAKEUP_ALIMTALK_MAX_ATTEMPTS=5
# MAKEUP_WORKER_INTERVAL_MS=60000

# 단일 문항 영구 PDF 캐시 워커 (service role + XeLaTeX 필요)
# QUESTION_RENDER_WORKER_BATCH_SIZE=4
# QUESTION_RENDER_WORKER_INTERVAL_MS=1500
# QUESTION_RENDER_WORKER_STALE_MS=600000
# QUESTION_RENDER_WORKER_NAME=
# QUESTION_RENDER_WARM_BATCH_MAX=100
