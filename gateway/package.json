{
  "name": "yggdrasill-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:prod": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:all": "concurrently -k -n gateway,pb-api,pb-extract,pb-figure,pb-export -c blue,cyan,magenta,yellow,green \"node src/index.js\" \"node src/problem_bank_api.js\" \"node src/problem_bank_extract_worker.js\" \"node src/problem_bank_figure_worker.js\" \"node src/problem_bank_export_worker.js\"",
    "pm2:start": "pm2 start ecosystem.config.cjs --only ygg-gateway",
    "pm2:restart": "pm2 restart ygg-gateway",
    "pm2:logs": "pm2 logs ygg-gateway",
    "pm2:save": "pm2 save",
    "api:pb": "node src/problem_bank_api.js",
    "worker:alimtalk": "node src/attendance_alimtalk_worker.js",
    "worker:alimtalk:once": "node src/attendance_alimtalk_worker.js --once",
    "worker:makeup:alimtalk": "node src/makeup_alimtalk_worker.js",
    "worker:makeup:alimtalk:once": "node src/makeup_alimtalk_worker.js --once",
    "worker:pb-extract": "node src/problem_bank_extract_worker.js",
    "worker:pb-extract:once": "node src/problem_bank_extract_worker.js --once",
    "worker:pb-figure": "node src/problem_bank_figure_worker.js",
    "worker:pb-figure:once": "node src/problem_bank_figure_worker.js --once",
    "worker:pb-export": "node src/problem_bank_export_worker.js",
    "worker:pb-export:once": "node src/problem_bank_export_worker.js --once",
    "test:pb": "node --test test/problem_bank_export_render_contract.test.js",
    "test:pb-extract": "node --test test/problem_bank_extract_regression.test.js",
    "test:pb-all": "node --test test/",
    "quality:pb": "node src/problem_bank_quality_gate.js",
    "quality:pb:metrics": "node src/problem_bank_quality_metrics.js"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.45.4",
    "adm-zip": "^0.5.16",
    "ajv": "^8.12.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.5.9",
    "he": "^1.2.0",
    "mathjax-full": "^3.2.1",
    "mqtt": "^5.3.4",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^24.40.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
